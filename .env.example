# Required — specialist nodes are tool-calling LLM agents.
OPENAI_API_KEY=

# Optional: override the default model used for parsing and narrative.
KV_LLM_MODEL=gpt-4o-mini

# Latency tuning (see README "Performance"):
# KV_FAST_PATH=auto   # default: skip LLM orchestration for case folders (on)
KV_FAST_PATH=0      # force full LLM agent loop on every node (slowest, richest trace)
# KV_FAST_NARRATIVE=1 # use templated report prose instead of LLM (fastest)
